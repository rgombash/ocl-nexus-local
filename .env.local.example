# ════════════════════════════════════════════════════════════════════════════
# NEXUS LOCAL — Example Configuration
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
#
# TWO setups are supported:
#   A) Docker Compose (recommended) — `docker compose up -d`
#      docker-compose.yml sets all env vars itself. .env.local is only read
#      by the dev override (docker-compose.dev.yml) via the bind mount.
#
#   B) Host dev server — `npm run dev` against a local Postgres + K3s
#      .env.local is read directly by Next.js. All values below are required.
# ════════════════════════════════════════════════════════════════════════════

# ─── Mode ───────────────────────────────────────────────────────────────────
NEXUS_MODE=local
NEXT_PUBLIC_NEXUS_MODE=local        # exposes mode to browser-side code
INFRA_DOMAIN=localhost              # workload subdomain root (*.localhost)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────────────────────────
# Setup A (Docker Compose dev override): use the internal service hostname
# DATABASE_URL=postgresql://nexus:nexus@nexus-db:5432/nexus
#
# Setup B (host dev server): use localhost
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# ─── Security ───────────────────────────────────────────────────────────────
# Must be EXACTLY 32 ASCII characters — used as raw AES-256-GCM key bytes.
# Generate one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24)[:32])"
#   openssl rand -base64 24 | head -c 32
ENCRYPTION_KEY=REPLACE_WITH_YOUR_32_ASCII_CHAR_KEY

# ─── Kubernetes ─────────────────────────────────────────────────────────────
# Setup A (Docker Compose dev override): the shared volume path inside the container
# KUBECONFIG_PATH=/shared/k3s/kubeconfig
#
# Setup B (host dev server): absolute path to your kubeconfig on the host
KUBECONFIG_PATH=/home/user/.kube/config

# ─── Authentication (Mock) ──────────────────────────────────────────────────
# All requests are treated as this single dev user — no login required.
LOCAL_DEV_USER_ID=00000000-0000-0000-0000-000000000000

# ─── Supabase (dummy values — required by the SDK even in local mode) ───────
# The Supabase client library is imported at module level and will throw if
# these are unset. Local mode never makes real Supabase calls.
NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-anon-key
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key
SUPABASE_ANON_KEY=dummy-anon-key
