# Nexus Local — Integration Test Configuration
# Copy this file to .env.test and fill in your values.
# tests/.env.test is gitignored — never commit it.

# Your Nexus API key (format: nx_...)
# Get it from: docker compose logs nexus-init | grep "nx_"
# Or from Dashboard → Settings → API Keys
NEXUS_API_KEY=nx_your_api_key_here

# Base URL for the Nexus platform (no trailing slash)
NEXUS_BASE_URL=http://localhost:3000

# Infrastructure domain for public workload URLs
# Linux: localhost (systemd-resolved handles *.localhost natively)
# macOS / Windows: localtest.me (or whatever INFRA_DOMAIN you set in docker-compose.yml)
INFRA_DOMAIN=localhost

# Blueprint to test with (default: python-sandbox)
TEST_BLUEPRINT_ID=python-sandbox

# Optional: Skip cleanup to preserve instance for manual inspection (useful for debugging)
# SKIP_CLEANUP=true
