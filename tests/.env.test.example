# Nexus API Integration Test Configuration
# Copy this file to .env.test and fill in your values

# Your Nexus API key (format: nx_...)
NEXUS_API_KEY=nx_your_api_key_here

# Base URL for the Nexus platform (no trailing slash)
NEXUS_BASE_URL=https://oclhosting.com

# Infrastructure domain for public URLs (e.g., oclhosting.com)
INFRA_DOMAIN=oclhosting.com

# Blueprint to test with (default: python-sandbox)
TEST_BLUEPRINT_ID=python-sandbox

# Optional: Skip cleanup to preserve instance for manual inspection
# Set to true to keep instances after test (for debugging)
# SKIP_CLEANUP=true

# Optional: Use existing instance instead of deploying new one
# Useful when testing against production without node infrastructure
# Format: just the short ID (e.g., 0463a280 from inst-0463a280)
# Leave commented out to test full deployment workflow
# TEST_INSTANCE_ID=0463a280

# ── UI Test Configuration (Session-based Authentication) ──
TEST_USER_EMAIL=test@foo.bar
TEST_USER_PASSWORD=your_secure_test_password

# Supabase credentials for session authentication
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here